<configuration>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - [corrId=%X{CORRELATION_KEY}] - %replace(%msg){'[\r\n]', '_'} - %kvp%n
            </pattern>

            <!-- The %X adds MDC key. %replace(%msg){'[\r\n]', '_'} Prints the message but escapes CRLF chars -->

        </encoder>
    </appender>

    <!-- Async wrapper -->
    <appender name="ASYNC" class="ch.qos.logback.classic.AsyncAppender">
        <!-- Queue size -->
        <queueSize>5000</queueSize>
        <!-- Never discard INFO/WARN/ERROR logs -->
        <discardingThreshold>0</discardingThreshold>
        <!-- Block when queue is full instead of dropping logs -->
        <neverBlock>false</neverBlock>
        <appender-ref ref="CONSOLE"/>
    </appender>

    <root level="INFO">
        <appender-ref ref="ASYNC"/>
    </root>

    <!-- Reduce noise -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.hibernate" level="WARN"/>

</configuration>